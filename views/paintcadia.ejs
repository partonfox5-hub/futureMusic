<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <style>
        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            background-color: #000;
        }
        iframe {
            width: 100%;
            height: 100%;
            border: none;
            display: block;
        }
        .back-btn {
            position: absolute;
            top: 20px;
            left: 20px;
            z-index: 50;
            background: rgba(0, 0, 0, 0.7);
            border: 2px solid #D4AF37;
            color: #D4AF37;
            padding: 10px 20px;
            text-decoration: none;
            font-family: sans-serif;
            font-weight: bold;
            text-transform: uppercase;
            border-radius: 4px;
            transition: all 0.3s ease;
        }
        .back-btn:hover {
            background: #D4AF37;
            color: #000;
        }
    </style>
</head>
<body>
    <a href="/projects" class="back-btn">&larr; Back to Projects</a>
    <iframe src="/paintcadia/index.html" allowfullscreen="true"></iframe>
</body>
</html>