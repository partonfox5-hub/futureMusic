<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= title %></title>
    <style>
        body { margin: 0; font-family: Arial, sans-serif; background: #111; color: #ddd; height: 100vh; display: flex; flex-direction: column; }
        .header { background: #000; padding: 15px; display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #333; }
        .header a { color: #00ffcc; text-decoration: none; font-weight: bold; border: 1px solid #00ffcc; padding: 8px 15px; border-radius: 4px; }
        .split-container { display: flex; flex: 1; overflow: hidden; }
        .pane { flex: 1; padding: 20px; overflow-y: auto; }
        .pane-left { border-right: 2px solid #333; background: #1a1a1a; }
        .pane-right { background: #0a0a0a; }
        
        /* Transcript Styles */
        .transcript-line { display: block; padding: 2px 5px; border-radius: 3px; transition: background 0.3s; }
        .line-num { color: #666; margin-right: 15px; user-select: none; }
        
        /* Highlight Classes */
        .highlight-green { background-color: rgba(0, 255, 0, 0.2); color: #00ff00; }
        
        /* Citation Link */
        .citation { color: #00ffcc; text-decoration: underline; cursor: pointer; padding: 2px 4px; border-radius: 3px; transition: 0.3s; }
        .citation:hover { background: rgba(0, 255, 204, 0.2); }
        
        /* Draggable Divider Styles */
        .resizer {
            width: 10px;
            background: #222;
            cursor: col-resize;
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 10;
            border-left: 1px solid #333;
            border-right: 1px solid #333;
        }
        .resizer:hover, .resizer:active {
            background: #00ffcc;
        }
        .resizer::after {
            content: "⋮";
            color: #666;
            font-size: 20px;
        }
    </style>
</head>
<body>

<div class="header">
    <div style="display: flex; align-items: center; gap: 15px;">
        <h2 style="margin: 0;"><%= title %></h2>
        <% if (typeof catalog !== 'undefined') { %>
        <select onchange="if(this.value) window.location.href=this.value" style="padding: 8px; background: #222; color: #00ffcc; border: 1px solid #00ffcc; border-radius: 4px; font-weight: bold; cursor: pointer; max-width: 300px;">
            <option value="" disabled>-- Switch Document --</option>
            <% catalog.filter(item => item.type === 'split-screen').forEach(item => { %>
                <option value="/justice/review/<%= item.id %>" <%= item.id === doc.id ? 'selected' : '' %>>
                    <%= item.title %>
                </option>
            <% }) %>
        </select>
        <% } %>
    </div>
    <a href="/justice" onclick="saveTime()">Return to Portal</a>
</div>

<div class="split-container" id="split-container">
    <!-- LEFT PANE: TRANSCRIPT -->
    <div class="pane pane-left" id="pane-left" style="display: flex; flex-direction: column; flex: 0 0 50%;">
        <h3 style="color: #fff;">Court Document</h3>
        <hr style="border-color: #333; width: 100%;">
        <div style="flex: 1;">
            <% if (doc.url && doc.url.endsWith('.pdf')) { %>
                <iframe src="<%= doc.url %>" width="100%" height="100%" style="border: none; min-height: 750px;"></iframe>
            <% } else { %>
                <p style="color: #ff5555;">Document format not supported.</p>
            <% } %>
        </div>
    </div>

    <!-- DRAGGABLE DIVIDER -->
    <div class="resizer" id="drag-resizer"></div>

    <!-- RIGHT PANE: AI ANALYSIS -->
    <div class="pane pane-right" id="pane-right" style="display: flex; flex-direction: column; flex: 1;">
        <h3 style="color: #fff;">AI Objective Analysis</h3>
        <hr style="border-color: #333; width: 100%;">
        <div style="flex: 1;">
            <% if (doc.aiAnalysisUrl) { %>
                <iframe src="<%= doc.aiAnalysisUrl %>" width="100%" height="100%" style="border: none; min-height: 750px;"></iframe>
            <% } else { %>
                <p style="color: #aaa;">No AI Analysis document mapped for this file yet.</p>
            <% } %>
        </div>
    </div>
</div>

<script>
    // 1. Time Tracking Logic
    let timeSpent = 0;
    const docId = '<%= doc.id %>';
    
    setInterval(() => { timeSpent++; }, 1000);

     function saveTime() {
        let tracking = JSON.parse(localStorage.getItem('justice_time_tracking') || '{}');
        tracking[docId] = (tracking[docId] || 0) + timeSpent;
        localStorage.setItem('justice_time_tracking', JSON.stringify(tracking));
    }

    // 2. Draggable Split Screen Logic
    const resizer = document.getElementById('drag-resizer');
    const leftPane = document.getElementById('pane-left');
    const container = document.getElementById('split-container');
    let isResizing = false;

    resizer.addEventListener('mousedown', (e) => {
        isResizing = true;
        document.body.style.cursor = 'col-resize';
        // Disable iframe pointer events while dragging so the mouse doesn't get "stuck" inside the PDF viewer
        document.querySelectorAll('iframe').forEach(iframe => iframe.style.pointerEvents = 'none');
    });

    document.addEventListener('mousemove', (e) => {
        if (!isResizing) return;
        const containerRect = container.getBoundingClientRect();
        // Calculate new width percentage based on mouse position
        let newWidth = ((e.clientX - containerRect.left) / containerRect.width) * 100;
        
        // Constrain the drag so neither side disappears completely (min 15%, max 85%)
        if (newWidth < 15) newWidth = 15;
        if (newWidth > 85) newWidth = 85;
        
        leftPane.style.flex = `0 0 ${newWidth}%`;
    });

    document.addEventListener('mouseup', () => {
        if (isResizing) {
            isResizing = false;
            document.body.style.cursor = 'default';
            // Re-enable iframe pointer events
            document.querySelectorAll('iframe').forEach(iframe => iframe.style.pointerEvents = 'auto');
        }
    });
</script>

</body>
</html>